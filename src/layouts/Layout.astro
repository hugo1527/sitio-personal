---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sitio personal de Debora - Abogada de Estudio Jurídico con enlaces a cursos y contacto." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Tipografías elegantes para un estudio de abogados -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		
		<title>{title}</title>
	</head>
	<body class="legal-pattern text-slate-800 min-h-screen flex flex-col justify-between py-12 px-6 sm:px-12 bg-[#f8fafc]">
		<!-- Gradiente de luz elegante -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-96 bg-[#b57a31]/5 rounded-full blur-[120px] pointer-events-none -z-10" />

		<slot />
	</body>
</html>

<style is:global>
	/* Tipografías y fondos globales para Astro */
	:root {
		--font-serif: 'Cormorant Garamond', Georgia, serif;
		--font-sans: 'Inter', sans-serif;
	}
	
	body {
		font-family: var(--font-sans);
	}

	.legal-pattern {
		background-color: #f8fafc;
		background-image: 
			radial-gradient(at 0% 0%, rgba(181, 122, 49, 0.03) 0px, transparent 50%),
			radial-gradient(at 100% 0%, rgba(15, 23, 42, 0.02) 0px, transparent 50%);
	}
</style>